# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: only needed for guild-scoped deploy script
DISCORD_GUILD_ID=

# Current Supabase runtime (used when DATABASE_URL is empty)
SUPABASE_URL=https://ontflizqvczcpbbpwvgg.supabase.co
SUPABASE_KEY=

# Optional external APIs
OMDB_KEY=

# Postgres mode toggle:
# - Leave empty to keep using Supabase
# - Set a value to enable Postgres-backed paths in db/store.js
# Example: postgres://cinemabro:cinemabro@postgres:5432/cinemabro
DATABASE_URL=

# Local postgres container config (used by docker compose)
POSTGRES_DB=cinemabro
POSTGRES_USER=cinemabro
POSTGRES_PASSWORD=change-me
